  "keyFeatures": [
    "App Router with React Server Components and nested layouts",
    "Pages Router for traditional file-system based routing",
    "Server-side rendering (SSR) and static site generation (SSG)",
    "Incremental Static Regeneration (ISR) for updating static pages",
    "Built-in image, font, and script optimization components",
    "Turbopack bundler for fast development and builds",
    "Server Actions for form handling and server-side mutations",
    "Route Handlers for building API endpoints",
    "Streaming and Suspense support for progressive rendering",
    "Built-in support for TypeScript, CSS Modules, Sass, and Tailwind CSS",
    "Middleware for request/response transformation",
    "Edge Runtime support for globally distributed functions",
    "use cache directive for fine-grained caching control",
    "Internationalization (i18n) routing support"
  ],
  "publicApiSurface": [
    "next/image - Image optimization component",
    "next/link - Client-side navigation Link component",
    "next/font - Font optimization with zero layout shift",
    "next/script - Script loading optimization component",
    "next/headers - cookies() and headers() server utilities",
    "next/navigation - useRouter, usePathname, useSearchParams, useParams hooks",
    "next/cache - revalidatePath, revalidateTag cache control functions",
    "next/server - NextRequest, NextResponse, middleware utilities",
    "next/og - ImageResponse for Open Graph image generation",
    "useRouter() - Pages Router navigation hook",
    "getServerSideProps() - Server-side data fetching",
    "getStaticProps() - Static site generation data fetching",
    "getStaticPaths() - Dynamic route path generation",
    "generateStaticParams() - App Router static params generation",
    "generateMetadata() - Dynamic metadata generation",
    "next.config.js / next.config.ts - Framework configuration",
    "create-next-app CLI - Project scaffolding tool",
    "next build / next dev / next start CLI commands"
  ]
}
